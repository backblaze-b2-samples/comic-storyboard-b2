# Backblaze B2 (S3-compatible API). Standardized B2_* names — these are the
# single source of truth; they are passed explicitly into
# S3StorageBackend.for_backblaze(...) so the genblaze-s3 env fallback never fires.
# B2_ENDPOINT is part of the standardized B2_* set and informational only here:
# genblaze-s3 derives the S3 endpoint from B2_REGION (it exposes no endpoint
# override on for_backblaze), so this value is not consumed by the sample.
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_APPLICATION_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
# Public base URL for the bucket — used so generated assets get durable public
# URLs the strip exporter can fetch (e.g. https://<bucket>.s3.<region>.backblazeb2.com).
B2_PUBLIC_URL_BASE=

# Replicate — image generation (FLUX-schnell ref sheets + consistent-character panels).
REPLICATE_API_TOKEN=

# Anthropic — the one non-Genblaze AI call (the story breaker, schema-forced tool use).
ANTHROPIC_API_KEY=
